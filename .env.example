# URLs dos webhooks do Google Apps Script que gravam as inscrições dos
# cursos no Google Sheets — uma planilha para a EFAL e outra para a Pós
# (campo `origem` em src/data/efal.ts e src/data/pos.ts escolhe qual).
# Dentro de cada planilha, a inscrição vai para a aba indicada pelo código
# do curso (campo `codigo`: CIT, CAL, CFO, CFP, CFL, CFM, CFC / POS-…).
#
# Variáveis de SERVIDOR — nunca renomear para NEXT_PUBLIC_*, para não expor
# as URLs no cliente. Configuradas pelo dono do projeto seguindo o
# GUIA-google-sheets.md. Sem a variável de uma origem, o site builda e roda
# normalmente; o modal daquela origem exibe um erro amigável ao enviar.
SHEETS_EFAL_WEBHOOK_URL=
SHEETS_POS_WEBHOOK_URL=

# URL do webhook do Apps Script que grava o formulário de contato da Home
# (seção #contato) em um Google Sheets SEPARADO do de inscrições — não
# reutilizar a URL acima. Mesmas regras: variável só de servidor; sem ela o
# formulário mostra o erro amigável e o build passa normalmente.
SHEETS_CONTATO_WEBHOOK_URL=
